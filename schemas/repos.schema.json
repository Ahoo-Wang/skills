{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ahoo Skills source repositories",
  "type": "object",
  "required": ["repos"],
  "additionalProperties": false,
  "properties": {
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^/]+$"
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "branch": {
            "type": "string",
            "minLength": 1,
            "default": "main"
          },
          "skills_path": {
            "type": "string",
            "minLength": 1,
            "default": "skills"
          },
          "plugins_path": {
            "type": "string",
            "minLength": 1,
            "default": "skills/plugins.json"
          }
        }
      }
    }
  }
}
