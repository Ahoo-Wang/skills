{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ahoo Skills upstream plugin metadata",
  "type": "object",
  "required": ["schemaVersion", "plugins"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description", "skills"],
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^/]+$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "skills": {
            "oneOf": [
              {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              {
                "type": "object",
                "properties": {
                  "include": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "default": ["*"]
                  },
                  "exclude": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "default": ["*-workspace"]
                  }
                }
              }
            ]
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "category": {
            "type": "string"
          },
          "interface": {
            "type": "object"
          },
          "policy": {
            "type": "object"
          }
        }
      }
    }
  }
}
